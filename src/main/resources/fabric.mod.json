  "description": "Auto-uses a healing item below a set HP% by simulating a hotbar switch and right-click.",
  "authors": ["Nexora"],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "com.nexora.hp.NexoraHpMod"
    ],
    "modmenu": [
      "com.nexora.hp.NexoraHpModMenu"
    ]
  },
  "depends": {
    "fabricloader": ">=0.19.0",
    "fabric-api": "*",
    "minecraft": "26.1"
  }
}
